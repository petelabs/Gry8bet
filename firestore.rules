rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Returns true if a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * PUBLIC DATA
     * All collections that are publicly readable but have restricted writes.
     * This includes match data, AI predictions, and system status needed for caching.
     */
    match /{collection}/{docId} where collection in ['matches', 'predictions', 'system', 'leagues', 'teams'] {
      // Allow anyone to read data for a fast, public-facing app.
      allow get, list: if true;
      
      // Only allow authenticated users to write data (i.e., trigger a cache update).
      // This prevents abuse of the external sports API.
      allow write: if isSignedIn();
    }
  }
}
