/**
 * @fileoverview Firestore Security Rules for the FootyForecast Application
 * @version 1.1
 *
 * @description
 * This ruleset establishes a security model for an application that displays public
 * football (soccer) match data and allows authenticated users to trigger data
 * synchronization.
 *
 * @philosophy
 * Core Philosophy: The security model is designed for a read-heavy, public-facing
 * application. All data is publicly readable. To manage API costs and improve
 * performance, write operations (for caching data from an external API) are
 * permitted only for authenticated users, simulating a trusted "cron job" process
 * on the client side.
 *
 * @structure
 * Data Structure: The database uses a flat, top-level collection structure. Each
 * main data type resides in its own collection. A `/system` collection is used
 * for internal metadata, such as tracking synchronization timestamps.
 *
 * @decisions
 * Key Security Decisions:
 * - Public Read Access: All data collections are publicly readable to support the app's
 *   primary function of displaying sports data to all users (`allow get, list: if true`).
 * - Authenticated Writes: Client-side write access is locked down to only
 *   authenticated users (`allow write: if request.auth != null;`). This allows
 *   logged-in users to initiate the data caching process from the API to Firestore,
 *   while preventing anonymous or malicious writes.
 * - No User-Specific Data: The data model does not contain any user-specific or
 *   private information, simplifying rules away from ownership-based logic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // -------------------------------------------------------------------------
    // Collection: /leagues, /teams, /matches, /predictions
    // -------------------------------------------------------------------------

    /**
     * @description
     *   Manages public football data. This data is publicly readable by anyone.
     *   Write operations are restricted to authenticated users, who are trusted
     *   to trigger the client-side data caching from the external API.
     * @path
     *   /leagues/{leagueId}
     *   /teams/{teamId}
     *   /matches/{matchId}
     *   /predictions/{predictionId}
     * @allow
     *   (read) Any user, signed in or not, can read data.
     *   (write) Only signed-in users can create, update, or delete data.
     */
    match /{collection}/{docId}
      where collection in ['leagues', 'teams', 'matches', 'predictions'] {
      allow get, list: if true;
      allow write: if isSignedIn();
    }
    
    // -------------------------------------------------------------------------
    // Collection: /system
    // -------------------------------------------------------------------------
    /**
     * @description
     *  Manages internal system metadata, like cron job timestamps.
     *  Publicly readable, but only writable by authenticated users.
     * @path
     *  /system/{docId}
     */
    match /system/{docId} {
        allow get, list: if true;
        allow write: if isSignedIn();
    }
  }
}
